DECISION_KEYWORDS = ("比較", "選定", "判断", "決めたい", "どれ", "優先", "優先順位", "choose", "compare", "decision", "decide", "prioritize", "priority")






DECISION_KEYWORDS = (
    "比較", "選定", "判断", "決めたい", "どれ", "優先", "優先順位",
    "choose", "compare", "decision", "decide", "prioritize", "priority",
)

def _contains_any(text: str, keywords) -> bool:
    t = (text or "").lower()
    for kw in keywords:
        if str(kw).lower() in t:
            return True
    return False

def choose_skill(text: str) -> tuple[str, str]:
    t = (text or "").strip()
    if _contains_any(t, DECISION_KEYWORDS):
        return "decision", "decision_keyword_match"
    return "research", "keyword match"

def apply_telegram_batch_summary(result):
    if not isinstance(result, dict):
        return result

    summary = format_telegram_batch_summary(result)
    if summary:
        result["reply_text"] = summary

    return result

def format_telegram_batch_summary(result):
    if not isinstance(result, dict):
        return None

    step_results = result.get("step_results")
    requested_steps = result.get("requested_steps")
    executed_steps = result.get("executed_steps")

    if not isinstance(step_results, list):
        return None
    if requested_steps is None and executed_steps is None:
        return None

    status = str(result.get("status") or "unknown")
    validate_only = bool(result.get("validate_only"))

    phase = "validation" if (validate_only or status.startswith("validated")) else "execution"

    lines = [f"[{phase}] {status}"]

    parts = []
    ok_count = result.get("ok_count")
    ng_count = result.get("ng_count")

    if isinstance(requested_steps, int):
        parts.append(f"requested={requested_steps}")
    if isinstance(executed_steps, int):
        parts.append(f"executed={executed_steps}")
    if isinstance(ok_count, int):
        parts.append(f"ok={ok_count}")
    if isinstance(ng_count, int):
        parts.append(f"ng={ng_count}")

    if parts:
        lines.append("steps " + " ".join(parts))

    first_failed_step_index = result.get("first_failed_step_index")
    first_failed_step_id = result.get("first_failed_step_id")
    first_failed_mode = result.get("first_failed_mode")
    first_failed_reason = result.get("first_failed_reason")

    if (
        first_failed_step_index is not None
        or first_failed_step_id
        or first_failed_mode
        or first_failed_reason
    ):
        failed = []
        if first_failed_step_index is not None:
            failed.append(f"index={first_failed_step_index}")
        if first_failed_step_id:
            failed.append(f"id={first_failed_step_id}")
        if first_failed_mode:
            failed.append(f"mode={first_failed_mode}")
        if first_failed_reason:
            failed.append(f"reason={first_failed_reason}")
        lines.append("first_failed " + " ".join(failed))

    completed_all_steps = result.get("completed_all_steps")
    has_errors = result.get("has_errors")
    stopped_early = result.get("stopped_early")

    flags = []
    if completed_all_steps is not None:
        flags.append(f"completed_all={str(bool(completed_all_steps)).lower()}")
    if has_errors is not None:
        flags.append(f"has_errors={str(bool(has_errors)).lower()}")
    if stopped_early is not None:
        flags.append(f"stopped_early={str(bool(stopped_early)).lower()}")

    if flags:
        lines.append("flags " + " ".join(flags))

    return "\n".join(lines)

