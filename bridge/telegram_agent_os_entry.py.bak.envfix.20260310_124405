#!/usr/bin/env python3
from __future__ import annotations

import json
import subprocess
import sys
from pathlib import Path


R = Path("/home/milky/agent-os")
REQUEST_RUNNER = R / "tools" / "run_agent_os_request.py"


def main() -> int:
    if len(sys.argv) < 2:
        print("usage: telegram_agent_os_entry.py 'message text' [chat_id]", file=sys.stderr)
        return 2

    text = sys.argv[1]
    chat = sys.argv[2] if len(sys.argv) > 2 else ""

    proc = subprocess.run(
        ["python3", str(REQUEST_RUNNER), text, "telegram"],
        capture_output=True,
        text=True,
        cwd=str(R),
        env={"PYTHONPATH": str(R)},
    )

    if proc.returncode != 0:
        msg = (proc.stderr or proc.stdout or "").strip()
        print(msg or "agent os request failed")
        return 1

    out = (proc.stdout or "").strip().splitlines()
    if not out:
        print("agent os request returned empty stdout")
        return 1

    try:
        obj = json.loads(out[-1])
    except Exception:
        print(out[-1].strip() or "invalid json from agent os request")
        return 1

    if not obj.get("ok"):
        print(obj.get("error") or "agent os request failed")
        return 1

    final_summary = (obj.get("final_summary") or "").strip()
    final_skill = obj.get("final_selected_skill") or "unknown"
    final_status = obj.get("final_status") or "unknown"
    root_task_id = obj.get("root_task_id") or "unknown"
    final_task_id = obj.get("final_task_id") or "unknown"

    reply = (
        f"{final_summary}\n"
        f"[root={root_task_id} final={final_task_id} skill={final_skill} status={final_status}]"
    ).strip()

    print(reply)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
