#!/usr/bin/env python3
from __future__ import annotations

import json
import os
import re
import secrets
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict

PROJECT_ROOT = Path(__file__).resolve().parents[1]
TASKS_DIR = PROJECT_ROOT / "state" / "tasks"


def utc_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()


def unique_suffix() -> str:
    ts = datetime.now(timezone.utc).strftime("%Y%m%d-%H%M%S-%f")
    rnd = secrets.token_hex(3)
    return f"{ts}-{rnd}"


def make_task_id() -> str:
    return f"task-{unique_suffix()}"


def atomic_write_json_new(path: Path, obj: Dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.tmp-{os.getpid()}-{secrets.token_hex(3)}")
    tmp.write_text(json.dumps(obj, ensure_ascii=False, indent=2), encoding="utf-8")
    try:
        os.link(tmp, path)
    except FileExistsError:
        tmp.unlink(missing_ok=True)
        raise FileExistsError(f"refusing to overwrite existing file: {path}")
    else:
        tmp.unlink(missing_ok=True)


def parse_json_suffix(text: str) -> Dict[str, Any]:
    m = re.search(r'\b(?:decision:\s*)?json\b\s*(\{.*\})\s*$', text, flags=re.DOTALL | re.IGNORECASE)
    if not m:
        raise ValueError("json plan not found")
    raw = m.group(1)
    obj = json.loads(raw)
    if not isinstance(obj, dict):
        raise ValueError("json payload must be an object")
    return obj


def build_single_step_plan_from_text(text: str) -> Dict[str, Any]:
    s = text.strip()

    m = re.match(
        r'^(?:aos\s+)?(?:decision:\s*)?(write!|write|append|read)\s+(.+)$',
        s,
        flags=re.DOTALL | re.IGNORECASE,
    )
    if not m:
        raise ValueError("unsupported execution command")

    raw_action = m.group(1).lower()
    rest = m.group(2).strip()

    if raw_action == "read":
        return {
            "steps": [
                {"action": "read", "path": rest}
            ]
        }

    if "\n" not in rest:
        raise ValueError(f"{raw_action} requires: <path> then newline then content")

    path_line, content = rest.split("\n", 1)
    path_str = path_line.strip()
    if not path_str:
        raise ValueError("path is empty")

    if raw_action == "append":
        return {
            "steps": [
                {"action": "append", "path": path_str, "content": content}
            ]
        }

    overwrite = raw_action == "write!"
    return {
        "steps": [
            {"action": "write", "path": path_str, "content": content, "overwrite": overwrite}
        ]
    }


def extract_execution_plan(message_text: str) -> Dict[str, Any]:
    s = message_text.strip()

    if re.match(r'^(?:aos\s+)?(?:decision:\s*)?json\b', s, flags=re.DOTALL | re.IGNORECASE):
        obj = parse_json_suffix(s)
        if "steps" not in obj:
            raise ValueError("json plan must contain steps")
        return obj

    if re.match(r'^(?:aos\s+)?(?:decision:\s*)?(write!|write|append|read)\b', s, flags=re.DOTALL | re.IGNORECASE):
        return build_single_step_plan_from_text(s)

    raise ValueError("not an execution command")


def create_execution_task(plan: Dict[str, Any], source_text: str) -> Dict[str, Any]:
    task_id = make_task_id()
    return {
        "id": task_id,
        "skill": "execution",
        "status": "queued",
        "created_at": utc_now(),
        "input": {
            "plan": plan
        },
        "meta": {
            "source": "route_to_task",
            "source_text": source_text,
            "runner": "python3 /home/milky/agent-os/runner/run_execution_task.py"
        }
    }


def route_message_to_task(message_text: str) -> Dict[str, Any]:
    plan = extract_execution_plan(message_text)
    task = create_execution_task(plan=plan, source_text=message_text)

    out_path = TASKS_DIR / f"{task['id']}.json"
    atomic_write_json_new(out_path, task)

    return {
        "ok": True,
        "task_id": task["id"],
        "task_path": str(out_path),
        "skill": task["skill"],
        "runner_command": f"python3 /home/milky/agent-os/runner/run_execution_task.py {out_path}",
        "plan": plan,
    }


def main() -> int:
    if len(sys.argv) < 2:
        print("usage: route_to_task.py '<message text>'", file=sys.stderr)
        return 2

    message_text = sys.argv[1]
    result = route_message_to_task(message_text)
    print(json.dumps(result, ensure_ascii=False, indent=2))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
