#!/usr/bin/env python3
from __future__ import annotations

import importlib.util
import json
import sys
import traceback
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, Callable

BASE_DIR = Path(__file__).resolve().parents[1]
TASKS_DIR = BASE_DIR / "state" / "tasks"
RESEARCH_IMPL = BASE_DIR / "skills" / "research" / "research_impl.py"


def now_iso() -> str:
    return datetime.now(timezone.utc).astimezone().isoformat()


def read_json(path: Path) -> Dict[str, Any]:
    return json.loads(path.read_text(encoding="utf-8"))


def write_json(path: Path, obj: Dict[str, Any]) -> None:
    path.write_text(json.dumps(obj, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def find_task_path(arg: str | None) -> Path:
    if arg:
        p = Path(arg)
        if not p.is_absolute():
            p = (BASE_DIR / p).resolve()
        if not p.exists():
            raise FileNotFoundError(f"task not found: {p}")
        return p

    candidates = []
    for p in sorted(TASKS_DIR.glob("task-*.json")):
        try:
            obj = read_json(p)
        except Exception:
            continue
        if obj.get("status") == "queued":
            candidates.append(p)

    if not candidates:
        raise FileNotFoundError("queued task not found")

    return candidates[0]


def load_module(path: Path, name: str):
    spec = importlib.util.spec_from_file_location(name, str(path))
    if spec is None or spec.loader is None:
        raise RuntimeError(f"failed to load module: {path}")
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    return mod


def pick_callable(mod: Any) -> Callable[[str], Any]:
    for fn_name in ("run_research", "execute", "research_impl", "main"):
        fn = getattr(mod, fn_name, None)
        if callable(fn):
            return fn
    raise RuntimeError("research callable not found in research_impl.py")


def normalize_query(task: Dict[str, Any]) -> str:
    candidates = [
        task.get("query"),
        task.get("input", {}).get("query") if isinstance(task.get("input"), dict) else None,
        task.get("payload", {}).get("query") if isinstance(task.get("payload"), dict) else None,
        task.get("router_result", {}).get("query") if isinstance(task.get("router_result"), dict) else None,
    ]
    for x in candidates:
        if isinstance(x, str) and x.strip():
            return x.strip()
    raise RuntimeError("query not found in task")


def normalize_skill(task: Dict[str, Any]) -> str:
    candidates = [
        task.get("selected_skill"),
        task.get("skill"),
        task.get("router_result", {}).get("selected_skill") if isinstance(task.get("router_result"), dict) else None,
    ]
    for x in candidates:
        if isinstance(x, str) and x.strip():
            return x.strip()
    raise RuntimeError("skill not found in task")


def run_research(query: str) -> Dict[str, Any]:
    mod = load_module(RESEARCH_IMPL, "agent_os_research_impl")
    fn = pick_callable(mod)
    out = fn(query)
    if isinstance(out, dict):
        return {
            "summary": str(out.get("summary", "")).strip(),
            "findings": list(out.get("findings", [])),
        }
    return {"summary": str(out).strip(), "findings": []}


def execute_task(task: Dict[str, Any]) -> Dict[str, Any]:
    skill = normalize_skill(task)
    query = normalize_query(task)

    if skill != "research":
        raise RuntimeError(f"unsupported skill: {skill}")

    result = run_research(query)
    return {
        "selected_skill": skill,
        "query": query,
        "result": result,
    }


def process_one(task_path: Path) -> Dict[str, Any]:
    task = read_json(task_path)
    task_id = task.get("task_id") or task_path.stem

    if task.get("status") not in (None, "queued", "failed"):
        return {
            "ok": False,
            "status": "skipped",
            "task_id": task_id,
            "task_path": str(task_path),
            "reason": f"task status is {task.get('status')}",
        }

    task["status"] = "running"
    task["started_at"] = now_iso()
    write_json(task_path, task)

    try:
        payload = execute_task(task)
        task["status"] = "completed"
        task["completed_at"] = now_iso()
        task["selected_skill"] = payload["selected_skill"]
        task["query"] = payload["query"]
        task["result"] = payload["result"]
        write_json(task_path, task)
        return {
            "ok": True,
            "status": "completed",
            "task_id": task_id,
            "task_path": str(task_path),
            "selected_skill": payload["selected_skill"],
        }
    except Exception as e:
        task["status"] = "failed"
        task["failed_at"] = now_iso()
        task["error"] = f"{type(e).__name__}: {e}"
        task["traceback"] = traceback.format_exc()
        write_json(task_path, task)
        return {
            "ok": False,
            "status": "failed",
            "task_id": task_id,
            "task_path": str(task_path),
            "error": task["error"],
        }


def main() -> int:
    arg = sys.argv[1] if len(sys.argv) >= 2 else None
    try:
        task_path = find_task_path(arg)
        out = process_one(task_path)
        print(json.dumps(out, ensure_ascii=False, indent=2))
        return 0 if out.get("ok") else 1
    except Exception as e:
        out = {
            "ok": False,
            "status": "error",
            "error": f"{type(e).__name__}: {e}",
        }
        print(json.dumps(out, ensure_ascii=False, indent=2))
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
