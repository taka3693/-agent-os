#!/usr/bin/env python3
from __future__ import annotations

import json
from pathlib import Path
from typing import Any, Dict


def run_critique(query: str) -> Dict[str, Any]:
    q = (query or "").strip()
    if not q:
        raise RuntimeError("critique query is empty")

    try:
        obj = json.loads(q)
    except Exception:
        return {
            "summary": f"critique dry-run completed for: {q}",
            "status": "ok",
            "issues": [
                "no structured critique input provided",
                "no artifact inspection performed",
            ],
            "decision": "revise",
        }

    if not isinstance(obj, dict):
        raise RuntimeError("critique query must be JSON object when structured")

    artifact = obj.get("artifact_path")
    if not isinstance(artifact, str) or not artifact.strip():
        raise RuntimeError("artifact_path is required for structured critique")

    p = Path(artifact)
    if not p.exists():
        raise RuntimeError(f"artifact not found: {artifact}")

    data = p.read_text(encoding="utf-8")
    issues = []
    diff_text = obj.get("diff") or ""

    if not data:
        issues.append("file is empty")
    if not data.endswith("\n"):
        issues.append("file does not end with newline")
    if len(data) > 5000:
        issues.append("file is relatively large for current simple critique rule set")
    if not diff_text:
        issues.append("diff missing")
    elif len(diff_text) > 3500:
        issues.append("diff is large; review quality may degrade")

    decision = "approve" if not issues else "revise"

    return {
        "summary": f"critique reviewed artifact: {p.name}",
        "status": "ok",
        "issues": issues,
        "decision": decision,
        "artifact_path": str(p),
        "bytes": len(data.encode('utf-8')),
        "content_preview": data[:400],
        "diff_preview": diff_text[:800],
    }


if __name__ == "__main__":
    print(run_critique('{"artifact_path":"/tmp/x.txt","diff":"x"}'))
