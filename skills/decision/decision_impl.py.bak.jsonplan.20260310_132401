#!/usr/bin/env python3
from __future__ import annotations

import json
import re
from typing import Any, Dict


def build_execution_request(action: str, path: str, content: str | None = None) -> str:
    obj = {
        "action": action,
        "path": path,
    }
    if content is not None:
        obj["content"] = content
    return json.dumps(obj, ensure_ascii=False)


def build_execution_plan(path: str, first: str, second: str) -> str:
    return json.dumps({
        "steps": [
            {"action": "write", "path": path, "content": first},
            {"action": "append", "path": path, "content": second},
            {"action": "read", "path": path},
        ]
    }, ensure_ascii=False)


def build_execution_plan2(path1: str, content1: str, path2: str, content2: str) -> str:
    return json.dumps({
        "steps": [
            {"action": "write", "path": path1, "content": content1},
            {"action": "write", "path": path2, "content": content2},
            {"action": "read", "path": path1},
            {"action": "read", "path": path2},
        ]
    }, ensure_ascii=False)


def run_decision(query: str) -> Dict[str, Any]:
    q = (query or "").strip()
    if not q:
        raise RuntimeError("decision query is empty")

    # plan2 path1 :: content1 || path2 :: content2
    m = re.match(r"^plan2\s+(\S+)\s*::\s*(.*?)\s*\|\|\s*(\S+)\s*::\s*(.*)$", q, re.DOTALL)
    if m:
        path1 = m.group(1).strip()
        content1 = m.group(2)
        path2 = m.group(3).strip()
        content2 = m.group(4)
        return {
            "summary": f"decision produced two-file execution plan: {path1}, {path2}",
            "status": "ok",
            "decision": "proceed",
            "reasoning": [
                "recognized plan2 command syntax",
                "converted command into structured two-file execution request",
            ],
            "next_skill": "execution",
            "next_query": build_execution_plan2(path1, content1, path2, content2),
        }

    # plan write+append+read path :: first :: second
    m = re.match(r"^plan\s+(\S+)\s*::\s*(.*?)\s*::\s*(.*)$", q, re.DOTALL)
    if m:
        path = m.group(1).strip()
        first = m.group(2)
        second = m.group(3)
        return {
            "summary": f"decision produced multi-step execution plan: {path}",
            "status": "ok",
            "decision": "proceed",
            "reasoning": [
                "recognized plan command syntax",
                "converted plan into structured multi-step execution request",
            ],
            "next_skill": "execution",
            "next_query": build_execution_plan(path, first, second),
        }

    # write path :: content
    m = re.match(r"^write\s+(\S+)\s*::\s*(.*)$", q, re.DOTALL)
    if m:
        path = m.group(1).strip()
        content = m.group(2)
        return {
            "summary": f"decision produced execution plan: write {path}",
            "status": "ok",
            "decision": "proceed",
            "reasoning": [
                "recognized write command syntax",
                "converted command into structured execution request",
            ],
            "next_skill": "execution",
            "next_query": build_execution_request("write", path, content),
        }

    # append path :: content
    m = re.match(r"^append\s+(\S+)\s*::\s*(.*)$", q, re.DOTALL)
    if m:
        path = m.group(1).strip()
        content = m.group(2)
        return {
            "summary": f"decision produced execution plan: append {path}",
            "status": "ok",
            "decision": "proceed",
            "reasoning": [
                "recognized append command syntax",
                "converted command into structured execution request",
            ],
            "next_skill": "execution",
            "next_query": build_execution_request("append", path, content),
        }

    # read path
    m = re.match(r"^read\s+(\S+)\s*$", q, re.DOTALL)
    if m:
        path = m.group(1).strip()
        return {
            "summary": f"decision produced execution plan: read {path}",
            "status": "ok",
            "decision": "proceed",
            "reasoning": [
                "recognized read command syntax",
                "converted command into structured execution request",
            ],
            "next_skill": "execution",
            "next_query": build_execution_request("read", path),
        }

    return {
        "summary": f"decision dry-run completed for: {q}",
        "status": "ok",
        "decision": "proceed",
        "reasoning": [
            "query was received",
            "no structured execution command matched",
            "fallback decision behavior used",
        ],
        "next_skill": "execution",
    }


if __name__ == "__main__":
    print(run_decision("plan2 notes/a.txt :: alpha || notes/b.txt :: beta"))
