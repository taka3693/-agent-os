#!/usr/bin/env python3
from __future__ import annotations

import json
import re
from typing import Any, Dict


def build_execution_request(action: str, path: str, content: str | None = None) -> str:
    obj = {
        "action": action,
        "path": path,
    }
    if content is not None:
        obj["content"] = content
    return json.dumps(obj, ensure_ascii=False)


def run_decision(query: str) -> Dict[str, Any]:
    q = (query or "").strip()
    if not q:
        raise RuntimeError("decision query is empty")

    # write path :: content
    m = re.match(r"^write\s+(\S+)\s*::\s*(.*)$", q, re.DOTALL)
    if m:
        path = m.group(1).strip()
        content = m.group(2)
        return {
            "summary": f"decision produced execution plan: write {path}",
            "status": "ok",
            "decision": "proceed",
            "reasoning": [
                "recognized write command syntax",
                "converted command into structured execution request",
            ],
            "next_skill": "execution",
            "next_query": build_execution_request("write", path, content),
        }

    # append path :: content
    m = re.match(r"^append\s+(\S+)\s*::\s*(.*)$", q, re.DOTALL)
    if m:
        path = m.group(1).strip()
        content = m.group(2)
        return {
            "summary": f"decision produced execution plan: append {path}",
            "status": "ok",
            "decision": "proceed",
            "reasoning": [
                "recognized append command syntax",
                "converted command into structured execution request",
            ],
            "next_skill": "execution",
            "next_query": build_execution_request("append", path, content),
        }

    # read path
    m = re.match(r"^read\s+(\S+)\s*$", q, re.DOTALL)
    if m:
        path = m.group(1).strip()
        return {
            "summary": f"decision produced execution plan: read {path}",
            "status": "ok",
            "decision": "proceed",
            "reasoning": [
                "recognized read command syntax",
                "converted command into structured execution request",
            ],
            "next_skill": "execution",
            "next_query": build_execution_request("read", path),
        }

    return {
        "summary": f"decision dry-run completed for: {q}",
        "status": "ok",
        "decision": "proceed",
        "reasoning": [
            "query was received",
            "no structured execution command matched",
            "fallback decision behavior used",
        ],
        "next_skill": "execution",
    }


if __name__ == "__main__":
    print(run_decision("write notes/demo.txt :: hello"))
