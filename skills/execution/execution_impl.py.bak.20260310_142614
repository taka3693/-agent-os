from __future__ import annotations

import json
import os
import secrets
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict, List

from skills.execution.execution_plan_validator import validate_execution_plan

WORKSPACE_ROOT = Path("/home/milky/agent-os/workspace")
RUNS_DIR = Path("/home/milky/agent-os/state/runs")


def _now_utc_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()


def _safe_task_id(task_id: str | None) -> str:
    raw = (task_id or "manual").strip()
    keep = []
    for ch in raw:
        if ch.isalnum() or ch in {"-", "_"}:
            keep.append(ch)
        else:
            keep.append("_")
    return "".join(keep)[:120] or "manual"


def _unique_suffix() -> str:
    ts = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%S%fZ")
    rnd = secrets.token_hex(3)
    return f"{ts}-{rnd}"


def _make_run_id(task_id: str | None) -> str:
    return f"run-{_unique_suffix()}-{_safe_task_id(task_id)}"


def _atomic_write_json_new(path: Path, obj: Dict[str, Any]) -> str:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.tmp-{os.getpid()}-{secrets.token_hex(3)}")
    tmp.write_text(json.dumps(obj, ensure_ascii=False, indent=2), encoding="utf-8")
    try:
        os.link(tmp, path)
    except FileExistsError:
        tmp.unlink(missing_ok=True)
        raise FileExistsError(f"refusing to overwrite existing file: {path}")
    else:
        tmp.unlink(missing_ok=True)
    return str(path)


def _write_run_summary(summary: Dict[str, Any]) -> str:
    out = RUNS_DIR / f"{summary['run_id']}.json"
    return _atomic_write_json_new(out, summary)


def _read_text(path: Path) -> str:
    return path.read_text(encoding="utf-8")


def _write_text(path: Path, content: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content, encoding="utf-8")


def _normalize_append_content(content: str) -> str:
    return content if content.endswith("\n") else content + "\n"


def _append_text(path: Path, content: str) -> int:
    path.parent.mkdir(parents=True, exist_ok=True)
    normalized = _normalize_append_content(content)
    with path.open("a", encoding="utf-8") as f:
        f.write(normalized)
    return len(normalized)


def run_execution_plan(
    plan: Dict[str, Any],
    task_id: str | None = None,
    workspace_root: str | Path = WORKSPACE_ROOT,
    runs_dir: str | Path = RUNS_DIR,
) -> Dict[str, Any]:
    global WORKSPACE_ROOT, RUNS_DIR
    WORKSPACE_ROOT = Path(workspace_root)
    RUNS_DIR = Path(runs_dir)

    run_id = _make_run_id(task_id)
    started_at = _now_utc_iso()
    artifacts: List[str] = []
    operations: List[Dict[str, Any]] = []

    try:
        validated = validate_execution_plan(plan=plan, workspace_root=WORKSPACE_ROOT)
        steps = validated["steps"]

        for idx, step in enumerate(steps, start=1):
            action = step["action"]
            rel_path = step["path"]
            abs_path = WORKSPACE_ROOT / rel_path

            op: Dict[str, Any] = {
                "index": idx,
                "action": action,
                "path": rel_path,
                "status": "ok",
            }

            if action == "read":
                if not abs_path.exists():
                    raise FileNotFoundError(f"read target not found: {rel_path}")
                content = _read_text(abs_path)
                op["chars"] = len(content)

            elif action == "write":
                overwrite = bool(step.get("overwrite", False))
                if abs_path.exists() and not overwrite:
                    raise FileExistsError(f"file already exists; use aos write! to overwrite: {rel_path}")
                content = step["content"]
                _write_text(abs_path, content)
                op["chars"] = len(content)
                op["overwrite"] = overwrite
                if rel_path not in artifacts:
                    artifacts.append(rel_path)

            elif action == "append":
                content = step["content"]
                written = _append_text(abs_path, content)
                op["chars"] = written
                op["normalized_newline"] = not content.endswith("\n")
                if rel_path not in artifacts:
                    artifacts.append(rel_path)

            operations.append(op)

        result = {
            "ok": True,
            "operation_count": len(operations),
            "artifacts": artifacts,
            "artifact_paths": artifacts,
            "operations": operations,
            "validation": validated["limits"],
        }

        summary = {
            "run_id": run_id,
            "timestamp": started_at,
            "task_id": task_id or "manual",
            "step_count": len(steps),
            "steps": steps,
            "artifacts": artifacts,
            "result": result,
            "error": None,
            "operation_count": len(operations),
        }
        result["run_log_path"] = _write_run_summary(summary)
        return result

    except Exception as e:
        failed_result = {
            "ok": False,
            "operation_count": len(operations),
            "artifacts": artifacts,
            "artifact_paths": artifacts,
            "operations": operations,
            "error": f"{type(e).__name__}: {e}",
        }
        summary = {
            "run_id": run_id,
            "timestamp": started_at,
            "task_id": task_id or "manual",
            "step_count": len(plan.get("steps", [])) if isinstance(plan, dict) else 0,
            "steps": plan.get("steps", []) if isinstance(plan, dict) else [],
            "artifacts": artifacts,
            "result": failed_result,
            "error": failed_result["error"],
            "operation_count": len(operations),
        }
        failed_result["run_log_path"] = _write_run_summary(summary)
        raise RuntimeError(json.dumps(failed_result, ensure_ascii=False))


def run_execution(
    plan: Dict[str, Any],
    task_id: str | None = None,
    workspace_root: str | Path = WORKSPACE_ROOT,
    runs_dir: str | Path = RUNS_DIR,
) -> Dict[str, Any]:
    return run_execution_plan(
        plan=plan,
        task_id=task_id,
        workspace_root=workspace_root,
        runs_dir=runs_dir,
    )


execute_plan = run_execution_plan
execute = run_execution_plan
run = run_execution_plan
