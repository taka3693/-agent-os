#!/usr/bin/env python3
from __future__ import annotations

import json
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict


ALLOWED_ROOT = Path("/home/milky/agent-os/workspace").resolve()
VALID_ACTIONS = {"read", "write", "append"}


def now_stamp() -> str:
    return datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")


def ensure_allowed_path(rel_path: str) -> Path:
    if not isinstance(rel_path, str) or not rel_path.strip():
        raise RuntimeError("path is required")

    p = (ALLOWED_ROOT / rel_path).resolve()

    try:
        p.relative_to(ALLOWED_ROOT)
    except ValueError:
        raise RuntimeError(f"path escapes allowed root: {rel_path}")

    return p


def parse_query(query: str) -> Dict[str, Any]:
    q = (query or "").strip()
    if not q:
        raise RuntimeError("execution query is empty")

    try:
        obj = json.loads(q)
    except Exception as e:
        raise RuntimeError("execution query must be valid JSON") from e

    if not isinstance(obj, dict):
        raise RuntimeError("execution query must be a JSON object")

    action = obj.get("action")
    if action not in VALID_ACTIONS:
        raise RuntimeError(f"unsupported action: {action}")

    path = obj.get("path")
    target = ensure_allowed_path(path)

    return {
        "action": action,
        "path": path,
        "target": target,
        "content": obj.get("content", ""),
    }


def backup_if_exists(target: Path) -> str | None:
    if not target.exists():
        return None
    bak = target.with_name(target.name + f".bak.{now_stamp()}")
    bak.write_text(target.read_text())
    return str(bak)


def run_execution(query: str) -> Dict[str, Any]:
    req = parse_query(query)
    action = req["action"]
    target: Path = req["target"]
    content = req["content"]

    target.parent.mkdir(parents=True, exist_ok=True)

    if action == "read":
        if not target.exists():
            raise RuntimeError(f"file not found: {req['path']}")
        data = target.read_text()
        return {
            "summary": f"execution read completed: {req['path']}",
            "status": "ok",
            "artifacts": [str(target)],
            "next_inputs": [],
            "operation": {
                "action": action,
                "path": req["path"],
                "bytes": len(data.encode("utf-8")),
                "content_preview": data[:400],
                "backup_path": None,
            },
        }

    if not isinstance(content, str):
        raise RuntimeError("content must be string for write/append")

    backup_path = backup_if_exists(target)

    if action == "write":
        target.write_text(content)
    elif action == "append":
        with target.open("a", encoding="utf-8") as f:
            f.write(content)
    else:
        raise RuntimeError(f"unsupported action: {action}")

    return {
        "summary": f"execution {action} completed: {req['path']}",
        "status": "ok",
        "artifacts": [str(target)],
        "next_inputs": [],
        "operation": {
            "action": action,
            "path": req["path"],
            "bytes_written": len(content.encode("utf-8")),
            "backup_path": backup_path,
        },
    }


if __name__ == "__main__":
    sample = json.dumps({
        "action": "write",
        "path": "notes/sample.txt",
        "content": "hello from execution skill\n"
    }, ensure_ascii=False)
    print(json.dumps(run_execution(sample), ensure_ascii=False, indent=2))
