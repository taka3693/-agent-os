#!/usr/bin/env python3
from __future__ import annotations

import difflib
import json
from datetime import datetime, timezone
from pathlib import Path
from typing import Any, Dict


ALLOWED_ROOT = Path("/home/milky/agent-os/workspace").resolve()
VALID_ACTIONS = {"read", "write", "append"}


def now_stamp() -> str:
    return datetime.now(timezone.utc).strftime("%Y%m%d_%H%M%S")


def ensure_allowed_path(rel_path: str) -> Path:
    if not isinstance(rel_path, str) or not rel_path.strip():
        raise RuntimeError("path is required")

    p = (ALLOWED_ROOT / rel_path).resolve()

    try:
        p.relative_to(ALLOWED_ROOT)
    except ValueError:
        raise RuntimeError(f"path escapes allowed root: {rel_path}")

    return p


def parse_query(query: str) -> Dict[str, Any]:
    q = (query or "").strip()
    if not q:
        raise RuntimeError("execution query is empty")

    try:
        obj = json.loads(q)
    except Exception as e:
        raise RuntimeError("execution query must be valid JSON") from e

    if not isinstance(obj, dict):
        raise RuntimeError("execution query must be a JSON object")

    action = obj.get("action")
    if action not in VALID_ACTIONS:
        raise RuntimeError(f"unsupported action: {action}")

    path = obj.get("path")
    target = ensure_allowed_path(path)

    return {
        "action": action,
        "path": path,
        "target": target,
        "content": obj.get("content", ""),
    }


def backup_if_exists(target: Path) -> str | None:
    if not target.exists():
        return None
    bak = target.with_name(target.name + f".bak.{now_stamp()}")
    bak.write_text(target.read_text(encoding="utf-8"), encoding="utf-8")
    return str(bak)


def unified_diff(before: str, after: str, path: str) -> str:
    lines = list(difflib.unified_diff(
        before.splitlines(keepends=True),
        after.splitlines(keepends=True),
        fromfile=f"{path}:before",
        tofile=f"{path}:after",
        lineterm=""
    ))
    return "".join(lines)[:4000]


def normalize_text_for_write(content: str) -> tuple[str, bool]:
    if content == "":
        return "\n", True
    if content.endswith("\n"):
        return content, False
    return content + "\n", True


def run_execution(query: str) -> Dict[str, Any]:
    req = parse_query(query)
    action = req["action"]
    target: Path = req["target"]
    content = req["content"]

    target.parent.mkdir(parents=True, exist_ok=True)

    if action == "read":
        if not target.exists():
            raise RuntimeError(f"file not found: {req['path']}")
        data = target.read_text(encoding="utf-8")
        return {
            "summary": f"execution read completed: {req['path']}",
            "status": "ok",
            "artifacts": [str(target)],
            "next_inputs": [],
            "operation": {
                "action": action,
                "path": req["path"],
                "bytes": len(data.encode("utf-8")),
                "content_preview": data[:400],
                "backup_path": None,
                "diff": "",
                "normalized_newline": False,
            },
        }

    if not isinstance(content, str):
        raise RuntimeError("content must be string for write/append")

    before = target.read_text(encoding="utf-8") if target.exists() else ""
    backup_path = backup_if_exists(target)
    normalized_content, normalized_newline = normalize_text_for_write(content)

    if action == "write":
        target.write_text(normalized_content, encoding="utf-8")
    elif action == "append":
        with target.open("a", encoding="utf-8") as f:
            f.write(normalized_content)
    else:
        raise RuntimeError(f"unsupported action: {action}")

    after = target.read_text(encoding="utf-8")
    diff_text = unified_diff(before, after, req["path"])

    return {
        "summary": f"execution {action} completed: {req['path']}",
        "status": "ok",
        "artifacts": [str(target)],
        "next_inputs": [],
        "operation": {
            "action": action,
            "path": req["path"],
            "bytes_written": len(normalized_content.encode("utf-8")),
            "backup_path": backup_path,
            "diff": diff_text,
            "normalized_newline": normalized_newline,
        },
    }


if __name__ == "__main__":
    sample = json.dumps({
        "action": "write",
        "path": "notes/sample.txt",
        "content": "hello from execution skill"
    }, ensure_ascii=False)
    print(json.dumps(run_execution(sample), ensure_ascii=False, indent=2))
