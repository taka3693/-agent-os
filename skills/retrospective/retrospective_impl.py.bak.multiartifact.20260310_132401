#!/usr/bin/env python3
from __future__ import annotations

import json
from typing import Any, Dict


def run_retrospective(query: str) -> Dict[str, Any]:
    q = (query or "").strip()
    if not q:
        raise RuntimeError("retrospective query is empty")

    try:
        obj = json.loads(q)
    except Exception:
        return {
            "summary": f"retrospective dry-run completed for: {q}",
            "status": "ok",
            "lessons": [
                "skill contract works",
                "structured chain context was not provided",
            ],
            "actions": [
                "propagate context across tasks",
                "improve retrospective summarization",
            ],
        }

    if not isinstance(obj, dict):
        raise RuntimeError("retrospective query must be JSON object when structured")

    chain = obj.get("chain", [])
    artifact_path = obj.get("artifact_path")
    critique_decision = obj.get("critique_decision")
    critique_issues = obj.get("critique_issues", [])

    lessons = []
    actions = []

    if artifact_path:
        lessons.append(f"artifact produced: {artifact_path}")
    if critique_decision:
        lessons.append(f"critique decision: {critique_decision}")
    if critique_issues:
        lessons.append(f"issue_count: {len(critique_issues)}")
        actions.append("address critique issues before broader automation")
    else:
        actions.append("promote current workflow to next richer execution scenario")

    if chain:
        lessons.append("chain observed: " + " -> ".join(chain))

    return {
        "summary": "retrospective completed for structured agent run",
        "status": "ok",
        "lessons": lessons,
        "actions": actions,
    }


if __name__ == "__main__":
    print(run_retrospective('{"chain":["decision","execution","critique","retrospective"]}'))
