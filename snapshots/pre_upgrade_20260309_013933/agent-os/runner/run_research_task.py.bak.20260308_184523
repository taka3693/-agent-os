#!/usr/bin/env python3
import json
import sys
from pathlib import Path
from datetime import datetime, timezone


def now_iso() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()


def read_task(path: Path) -> dict:
    with path.open("r", encoding="utf-8") as f:
        data = json.load(f)
    if not isinstance(data, dict):
        raise ValueError("task JSON must be an object")
    return data


def write_task(path: Path, task: dict) -> None:
    task["updated_at"] = now_iso()
    with path.open("w", encoding="utf-8") as f:
        json.dump(task, f, ensure_ascii=False, indent=2)
        f.write("\n")


def fail_task(path: Path, task: dict, stage: str, message: str) -> None:
    task["status"] = "failed"
    task["error"] = {"stage": stage, "message": message}
    write_task(path, task)


def run_dummy_research(query: str) -> dict:
    q = (query or "").strip() or "（query未指定）"
    findings = [
        f"依頼文を確認: {q}",
        "キーワード分解を実施: 比較/整理/要約の3観点で扱う",
        "次アクション案: 比較軸を3つに固定して情報を収集する",
    ]
    summary = "ダミー調査として、依頼文の要点抽出と比較観点の下準備を完了した。"
    return {"summary": summary, "findings": findings}


def process_task(path: Path) -> int:
    try:
        task = read_task(path)
    except Exception as e:
        print(json.dumps({"ok": False, "error": f"load failed: {e}"}, ensure_ascii=False))
        return 1

    required = ["task_id", "status", "selected_skill", "run_input"]
    for k in required:
        if k not in task:
            print(json.dumps({"ok": False, "error": f"missing field: {k}"}, ensure_ascii=False))
            return 1

    if task.get("status") != "queued":
        print(json.dumps({"ok": False, "error": f"status must be queued, got: {task.get('status')}"}, ensure_ascii=False))
        return 1

    if task.get("selected_skill") != "research":
        print(json.dumps({"ok": False, "error": f"selected_skill must be research, got: {task.get('selected_skill')}"}, ensure_ascii=False))
        return 1

    try:
        task["status"] = "running"
        task["result"] = None
        task["error"] = None
        write_task(path, task)
    except Exception as e:
        print(json.dumps({"ok": False, "error": f"save running failed: {e}"}, ensure_ascii=False))
        return 1

    try:
        run_input = task.get("run_input") or {}
        query = run_input.get("query", task.get("input_text", "")) if isinstance(run_input, dict) else task.get("input_text", "")
        result = run_dummy_research(query)

        task["result"] = result
        task["status"] = "completed"
        task["error"] = None
        write_task(path, task)

        print(json.dumps({
            "ok": True,
            "task_id": task.get("task_id"),
            "status": task.get("status"),
            "result_summary": result.get("summary", ""),
        }, ensure_ascii=False))
        return 0

    except Exception as e:
        try:
            fail_task(path, task, stage="run", message=str(e))
        except Exception as save_err:
            print(json.dumps({"ok": False, "error": f"run failed: {e}; additionally save failed: {save_err}"}, ensure_ascii=False))
            return 1

        print(json.dumps({"ok": False, "error": f"run failed: {e}"}, ensure_ascii=False))
        return 1


def main() -> int:
    if len(sys.argv) != 2:
        print(json.dumps({
            "ok": False,
            "error": "usage: python3 run_research_task.py /home/milky/agent-os/state/tasks/task-YYYYMMDD-XXX.json",
        }, ensure_ascii=False))
        return 1

    task_path = Path(sys.argv[1]).resolve()
    if not task_path.exists() or not task_path.is_file():
        print(json.dumps({"ok": False, "error": f"task file not found: {task_path}"}, ensure_ascii=False))
        return 1

    return process_task(task_path)


if __name__ == "__main__":
    raise SystemExit(main())
