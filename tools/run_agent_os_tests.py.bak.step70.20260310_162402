#!/usr/bin/env python3
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent

TESTS = [
    ROOT / "tests" / "test_step68_validate_only_summary.py",
]

def run_one(test_path: Path) -> int:
    if not test_path.exists():
        print(f"[NG] missing: {test_path}")
        return 1

    print(f"=== RUN {test_path.relative_to(ROOT)} ===")
    cp = subprocess.run(
        [sys.executable, str(test_path)],
        cwd=str(ROOT),
        text=True,
    )
    if cp.returncode == 0:
        print(f"=== OK  {test_path.relative_to(ROOT)} ===")
    else:
        print(f"=== NG  {test_path.relative_to(ROOT)} rc={cp.returncode} ===")
    return cp.returncode

def main() -> int:
    failed = 0
    ran = 0

    for test_path in TESTS:
        ran += 1
        rc = run_one(test_path)
        if rc != 0:
            failed += 1

    print()
    print(f"SUMMARY: ran={ran} failed={failed} passed={ran - failed}")

    return 0 if failed == 0 else 1

if __name__ == "__main__":
    raise SystemExit(main())
